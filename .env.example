# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# Stripe Price IDs
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_BUSINESS=price_your_business_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id

# ── E-Mail (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@kiclear.ai

# ── kicheck.ai Integration ────────────────────────────────────────────────────
KICHECK_TRANSFER_SECRET=your-shared-secret-min-32-chars
NEXT_PUBLIC_KICHECK_URL=https://kicheck.ai

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://kiclear.ai
NEXT_PUBLIC_APP_ENV=production
