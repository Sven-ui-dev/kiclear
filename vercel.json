{
  "framework": "nextjs",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",       "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/law-monitor",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/yearly-refresh",
      "schedule": "0 4 1 1 *"
    }
  ]
}
